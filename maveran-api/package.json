{
  "name": "maveran-api",
  "version": "1.0.0",
  "description": "Panelya operations platform REST API",
  "main": "server.js",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "start:pm2": "pm2 start ecosystem.config.cjs",
    "db:schema": "psql \"$DATABASE_URL\" -f db/schema.sql",
    "db:migrate": "node scripts/run-migrations.js",
    "db:seed": "psql \"$DATABASE_URL\" -f db/seed.sql",
    "demo:seed": "node scripts/seed-demo-workspace.js",
    "db:seed-demo": "npm run demo:seed",
    "db:setup": "npm run db:schema && npm run db:seed && npm run db:migrate",
    "deploy:staging": "npm run db:schema && npm run db:migrate && npm run db:seed-demo && npm start",
    "deploy:production": "npm run db:schema && npm run db:migrate && npm start",
    "admin:create": "node scripts/create-admin.js",
    "orders:expire-pending": "node scripts/expire-pending-orders.js",
    "production:check": "node scripts/production-check.js",
    "check:syntax": "node scripts/check-syntax.js",
    "smoke:auth": "powershell -ExecutionPolicy Bypass -File scripts/smoke-auth.ps1",
    "smoke:payment": "powershell -ExecutionPolicy Bypass -File scripts/smoke-payment.ps1",
    "smoke:payment:bash": "bash scripts/smoke-payment.sh",
    "secrets:generate": "node scripts/generate-secrets.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "iyzipay": "^2.0.67",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "pg": "^8.13.1",
    "sharp": "^0.33.5"
  }
}
