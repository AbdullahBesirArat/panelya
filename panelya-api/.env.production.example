NODE_ENV=production
DATABASE_URL=postgresql://panelya_user:CHANGE_STRONG_PASSWORD@localhost:5432/panelya
JWT_SECRET_APP=CHANGE_TO_A_CRYPTO_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_SECRET_ADMIN=CHANGE_TO_A_DIFFERENT_CRYPTO_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=2h
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=30
ADMIN_USERNAME=admin
ADMIN_ROLE=super_admin
ALLOW_ENV_ADMIN_LOGIN=false
ADMIN_PASSWORD_HASH=
CORS_ORIGIN=https://panelya.com.tr,https://www.panelya.com.tr,https://panelya-web.vercel.app,https://suvera.com.tr,https://www.suvera.com.tr
DEFAULT_ORGANIZATION_PLAN=growth
API_RATE_LIMIT=1200
LOGIN_RATE_LIMIT=10
REGISTER_RATE_LIMIT=6
ORDER_CREATE_RATE_LIMIT=60
PAYMENT_INIT_RATE_LIMIT=40
UPLOAD_RATE_LIMIT=40
UPLOAD_DIR=/var/www/panelya/uploads
PAYMENT_PROVIDER=iyzico
PAYMENT_CALLBACK_SECRET=CHANGE_TO_A_CRYPTO_RANDOM_SECRET_AT_LEAST_32_CHARS
EMAIL_PROVIDER=resend
EMAIL_FROM=notifications@example.com
RESEND_API_KEY=CHANGE_TO_RESEND_API_KEY
PUBLIC_SITE_URL=https://suvera.com.tr
PUBLIC_API_URL=https://api.panelya.com.tr
PAYMENT_CALLBACK_URL=https://api.panelya.com.tr/api/payment/callback
PAYMENT_SUCCESS_URL=https://suvera.com.tr/tesekkur.html
PAYMENT_FAILURE_URL=https://suvera.com.tr/tesekkur.html?payment=failed
IYZICO_API_KEY=CHANGE_IYZICO_API_KEY
IYZICO_SECRET_KEY=CHANGE_IYZICO_SECRET_KEY
IYZICO_BASE_URL=https://api.iyzipay.com
IYZICO_DEFAULT_IDENTITY_NUMBER=CHANGE_OR_COLLECT_FROM_CUSTOMER
PAYMENT_PENDING_TIMEOUT_MINUTES=30
PAYMENT_PENDING_EXPIRE_LIMIT=100
PAYMENT_MOCK_AUTO_PAY=false
PAYMENT_CALLBACK_SECRET_REQUIRED=true
DB_POOL_MAX=40
