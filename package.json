{
  "name": "panelya-platform",
  "version": "2.0.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "panelya-api"
  ],
  "scripts": {
    "dev:web": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build",
    "lint:web": "npm --prefix apps/web run lint",
    "typecheck:web": "npm --prefix apps/web run typecheck",
    "dev:api": "npm --prefix panelya-api run dev",
    "start": "npm run start:api",
    "start:api": "npm --prefix panelya-api run start",
    "check:api": "npm --prefix panelya-api run check:syntax",
    "db:migrate": "npm --prefix panelya-api run db:migrate",
    "db:setup": "npm --prefix panelya-api run db:setup",
    "demo:seed": "npm --prefix panelya-api run demo:seed",
    "db:seed-demo": "npm --prefix panelya-api run db:seed-demo",
    "deploy:api:staging": "npm --prefix panelya-api run deploy:staging",
    "deploy:api:production": "npm --prefix panelya-api run deploy:production",
    "deploy:staging": "npm --prefix panelya-api run deploy:staging",
    "deploy:production": "npm --prefix panelya-api run deploy:production",
    "smoke:auth": "npm --prefix panelya-api run smoke:auth",
    "smoke:auth:bash": "npm --prefix panelya-api run smoke:auth:bash",
    "smoke:payment": "npm --prefix panelya-api run smoke:payment",
    "smoke:payment:bash": "npm --prefix panelya-api run smoke:payment:bash",
    "check:production": "npm --prefix panelya-api run production:check",
    "secrets:generate": "npm --prefix panelya-api run secrets:generate"
  }
}
